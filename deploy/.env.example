# 跑步Agent 云端部署 - 环境变量
# 复制为 .env 并填写实际值

# MySQL（docker-compose 会创建数据库）
MYSQL_ROOT_PASSWORD=请设置强密码
MYSQL_PASSWORD=请设置强密码

# JWT 密钥（用于 OAuth Token，随机生成）
# 生成方式: openssl rand -hex 32
SECRET_KEY=请设置随机字符串

# 通义千问 API Key（AI 分析功能，可选）
QWEN_API_KEY=

# CORS 允许的源（多个用逗号分隔，* 表示允许所有）
CORS_ORIGINS=*

# OSS 对象存储（生产环境上传文件到 OSS，不设置则用本地目录）
# STORAGE_TYPE=oss 时必填
STORAGE_TYPE=local
OSS_BUCKET=
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
